# Copy variable names into your shell, launch profile, or CI secrets.
# ASP.NET Core maps nested config with double underscores: Section__Key
# Do not commit real values.

# Required for live LLM, embeddings, and agentic flows (empty → fallbacks where implemented)
Llm__ApiKey=

# Optional overrides
# Llm__Provider=Gemini
# Llm__Model=gemini-2.5-flash-lite
# Llm__EmbeddingModel=gemini-embedding-001

# WeatherAPI.com — omit or UseMock for deterministic demo data
WeatherApi__ApiKey=
# WeatherApi__UseMock=true

# AviationStack — omit or UseMock for deterministic demo data
AviationStack__ApiKey=
# AviationStack__UseMock=true

# MongoDB — empty string forces in-memory session store
MongoDb__ConnectionString=mongodb://localhost:27017

# JWT (required when Auth__Enabled=true). Minimum 32 characters.
# Auth__Enabled=true
# Auth__Jwt__SecretKey=your-32-plus-character-secret-key-here
# Auth__Jwt__Issuer=TravelDisruptionAgent
# Auth__Jwt__Audience=TravelDisruptionAgent.Spa
# Auth__AllowDevTokenEndpoint=true   # only for Development + POST /api/auth/dev-token

# Production: explicit SPA origin(s) for CORS (credentials enabled; no wildcards). Use indexed keys:
# AllowedOrigins__0=https://your-spa.example

# Production: API host names for Host header filtering (not *). Example:
# AllowedHosts=api.your-domain.example
