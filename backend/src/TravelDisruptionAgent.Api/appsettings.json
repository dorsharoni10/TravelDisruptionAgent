{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Http": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "System.Net.Http.HttpClient.LogicalHandler": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:5173"
  ],
  "Auth": {
    "Enabled": false,
    "AllowDevTokenEndpoint": false,
    "Jwt": {
      "SecretKey": "",
      "Issuer": "TravelDisruptionAgent",
      "Audience": "TravelDisruptionAgent.Spa",
      "AccessTokenExpiryMinutes": 120
    }
  },
  "RateLimiting": {
    "ChatPermitLimit": 30,
    "ChatWindowMinutes": 1,
    "PreferencesPermitLimit": 120,
    "PreferencesWindowMinutes": 1,
    "AuthTokenPermitLimit": 15,
    "AuthTokenWindowMinutes": 1
  },
  "Security": {
    "RequireHttpsRedirection": false,
    "HttpsPort": 443
  },
  "Orchestration": {
    "EnableConversationHistoryRouteFallback": true,
    "RedactSensitiveOrchestrationLogs": true
  },
  "Llm": {
    "Provider": "Gemini",
    "Model": "gemini-2.5-flash-lite",
    "Endpoint": "",
    "DeploymentName": "",
    "EmbeddingModel": "gemini-embedding-001",
    "EnableStreaming": true,
    "Temperature": 0.3,
    "MaxTokens": 4096
  },
  "WeatherApi": {
    "UseMock": false,
    "BaseUrl": "https://api.weatherapi.com/v1"
  },
  "AviationStack": {
    "UseMock": false,
    "BaseUrl": "https://api.aviationstack.com/v1",
    "IncludeFlightDateOnRouteSearch": false
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "TravelDisruptionAgent",
    "SessionsCollection": "conversation_sessions"
  },
  "Rag": {
    "PolicyRoutingMinSimilarity": 0.38,
    "DocumentRetrievalMinSimilarity": 0.32,
    "DefaultTopK": 1,
    "ToolsOnlyTopK": 1,
    "MaxChunkCharsForRetrieval": 900
  },
  "ConversationSession": {
    "MaxMessages": 6,
    "MaxTotalStoredChars": 16000,
    "MaxPromptChars": 12000
  },
  "Agentic": {
    "EnableAgenticRag": false,
    "MaxIterations": 4,
    "MaxConsecutiveParseFailures": 2,
    "MaxIdenticalPolicyQueries": 2,
    "MaxStagnationIterations": 2,
    "DefaultPolicyTopK": 1,
    "TranscriptRetentionObservations": 2,
    "TranscriptMaxChars": 6000
  }
}
