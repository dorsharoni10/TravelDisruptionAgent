# Leave empty in dev to use Vite proxy (/api -> http://localhost:5205).
# Set to full API URL when running `npm run preview` or a static build without proxy.
# VITE_API_BASE_URL=http://localhost:5205

VITE_API_BASE_URL=

# When true, the SPA requests a JWT from POST /api/auth/dev-token before load.
# Backend must have Auth:Enabled=true, Auth:Jwt:SecretKey (32+ chars), and (in Development) Auth:AllowDevTokenEndpoint=true.
# VITE_AUTH_ENABLED=true
# VITE_AUTH_SUB=demo-user
